{
  "name": "deeper",
  "private": true,
  "workspaces": [
    "web",
    "server"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm run -w server dev & npm run -w web dev",
    "dev:server": "npm run -w server dev",
    "dev:web": "npm run -w web dev",
    "build": "npm run -w server build && npm run -w web build",
    "start": "npm run -w server start",
    "typecheck": "npm -ws run typecheck --if-present",
    "lint": "npm -ws run lint --if-present"
  }
}
